---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MOUAD8EIGHT | Official Artist Portfolio",
  description = "Precision Techno Artist. Sculpting sonic landscapes through industrial rhythms and hypnotic frequencies.",
} = Astro.props;
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/images/m8e-logo-cropped.svg" />
    <link rel="icon" type="image/png" href="/images/m8e-logo-cropped.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Fonts: Space Grotesk (headline) + Inter (body/label) + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-body selection:bg-secondary selection:text-on-secondary">
    <slot />
    <script>
      const io = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              io.unobserve(e.target);
            }
          }),
        { rootMargin: "0px 0px -8% 0px", threshold: 0.1 }
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
