---
import { bio } from "../data/bio.js";
---

<section
  id="home"
  class="relative min-h-screen flex flex-col justify-center items-start px-8 md:px-24 overflow-hidden"
>
  <!-- Background: gradient left, video right -->
  <div class="absolute inset-0 z-0">
    <!-- Gradient overlay spans full width: solid dark on left, fades to transparent on right -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-[#0a0a0a] via-[#0a0a0a]/80 to-[#0a0a0a]/10 z-10"
    ></div>
    <!-- Video: right half only, top offset by navbar height (~80px) so DJ's head clears the nav -->
    <div class="absolute right-0 top-20 bottom-0 w-1/2 overflow-hidden hidden md:block">
      <video
        autoplay
        loop
        muted
        playsinline
        class="w-full h-full object-cover opacity-80"
      >
        <source src="/hero-bg.mp4" type="video/mp4" />
      </video>
    </div>
  </div>

  <!-- Main content — animate-hero staggers children on load -->
  <div class="animate-hero relative z-20 max-w-4xl">
    <!-- Eyebrow -->
    <span class="block text-secondary font-headline tracking-[0.3em] uppercase text-sm mb-4">
      {bio.tagline}
    </span>

    <!-- Name — each word is scrambled independently via JS -->
    <h1 class="text-7xl md:text-[12rem] font-bold sonic-monolith leading-[0.85] mb-8 text-white">
      <span data-scramble="MOUAD">MOUAD</span><br /><span data-scramble="8EIGHT">8EIGHT</span>
    </h1>

    <!-- Subline -->
    <p class="text-on-surface-variant text-lg md:text-xl max-w-xl mb-12 font-light leading-relaxed">
      Sculpting sonic landscapes through industrial rhythms and hypnotic
      frequencies. From the heart of Berlin to the global stage.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-6">
      <a
        href="#sets"
        class="group flex items-center gap-3 bg-white text-black px-8 py-4 font-headline uppercase tracking-widest text-sm hover:bg-secondary hover:text-on-secondary transition-all active:scale-95"
      >
        Watch Sets
        <span class="material-symbols-outlined text-base leading-none">play_arrow</span>
      </a>

      <a
        href="#booking"
        class="flex items-center gap-3 border border-outline/30 text-white px-8 py-4 font-headline uppercase tracking-widest text-sm hover:bg-white/5 transition-all active:scale-95"
      >
        Secure Booking
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-12 right-12 hidden md:block">
    <div
      class="flex flex-col items-end gap-2 text-on-surface-variant opacity-30 rotate-90 origin-bottom-right"
    >
      <span class="font-headline tracking-widest uppercase text-xs">Scroll to explore</span>
      <div class="w-24 h-px bg-on-surface-variant"></div>
    </div>
  </div>
</section>

<script>
  // Characters used during scramble — uppercase + numbers matches the title aesthetic
  const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#@$%!?-+";
  const DURATION = 1500; // ms

  const rand = (n: number) => Math.floor(Math.random() * n);

  document.querySelectorAll<HTMLElement>("[data-scramble]").forEach((el) => {
    const target = el.dataset.scramble ?? "";
    const n = target.length;
    let startTime: number | null = null;

    // lockAt(i): the progress value [0–1] at which character i reveals itself.
    // Spread from 0.10 → 0.85 so all chars scramble for ~150ms before locking.
    const lockAt = (i: number) => 0.1 + (i / Math.max(n - 1, 1)) * 0.75;

    const tick = (timestamp: number) => {
      if (!startTime) startTime = timestamp;
      const progress = Math.min((timestamp - startTime) / DURATION, 1);

      let output = "";
      for (let i = 0; i < n; i++) {
        output +=
          progress >= lockAt(i)
            ? target[i]
            : CHARS[rand(CHARS.length)];
      }

      el.textContent = output;

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        el.textContent = target; // guarantee exact final text
      }
    };

    requestAnimationFrame(tick);
  });
</script>
